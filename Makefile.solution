# Rules to run the OptoFlood experiment.

SOLUTION_INPUTS = box/solution/solution.$(PROVIDER).box \
                  experiment/app/producer.cpp \
                  experiment/app/consumer.cpp \
                  experiment/app/trust-schema.conf \
                  experiment/solution/Vagrantfile \
                  experiment/solution/Makefile \
                  experiment/tool/exp.py

# Same K=16 handoff sequence as baseline for an apples-to-apples comparison.
SOLUTION_HANDOFF_SEQUENCE = acc2,acc3,acc4,acc5,acc6,acc5,acc4,acc3,acc2,acc3,acc4,acc5,acc6,acc5,acc4,acc3,acc2
SOLUTION_HANDOFF_ENV = NLSR_HANDOFF_COUNT='16' NLSR_HANDOFF_INTERVAL_BASE='90' NLSR_HANDOFF_INTERVAL_JITTER='60' NLSR_HANDOFF_SEQUENCE='$(SOLUTION_HANDOFF_SEQUENCE)'

SOLUTION_RESULTS = results/solution/consumer_capture.pcap \
                   results/solution/pcap_nodes/core.pcap \
                   results/solution/pcap_nodes/agg1.pcap \
                   results/solution/pcap_nodes/agg2.pcap \
                   results/solution/pcap_nodes/acc1.pcap \
                   results/solution/pcap_nodes/acc2.pcap \
                   results/solution/pcap_nodes/acc3.pcap \
                   results/solution/pcap_nodes/acc4.pcap \
                   results/solution/pcap_nodes/acc5.pcap \
                   results/solution/pcap_nodes/acc6.pcap \
                   results/solution/pcap_nodes/producer.pcap \
                   results/solution/pcap_nodes/consumer.pcap \
                   results/solution/handoffs.txt

# Order-only prerequisites: the solution VM runs after the last baseline group
# and after the test validation passes.
$(SOLUTION_RESULTS) &: scripts/run-in-vm.sh $(SOLUTION_INPUTS) | test/.validate_ok $(subst XXX,g4-h36-a6-r9,$(BASELINE_EXPERIMENT_OUTPUTS))
	RUN_IN_VM_CLEAR_LOCAL=1 RUN_IN_VM_REMOTE_MAKE="$(SOLUTION_HANDOFF_ENV) make all" sh $^ $@


# Rules to process outputs from the OptoFlood experiment.

results/solution/consumer_capture.csv: results/solution/consumer_capture.pcap experiment/tool/ndn.lua
	tshark -X lua_script:experiment/tool/ndn.lua -r "$<" -T fields -e frame.time_epoch -e frame.len -e ndn.type -e ndn.name -E separator=, -E header=y -E quote=d > "$@"

results/solution/network_overhead.csv: experiment/tool/extract_overhead_csv.py \
                                       results/solution/pcap_nodes/core.pcap \
                                       results/solution/pcap_nodes/agg1.pcap \
                                       results/solution/pcap_nodes/agg2.pcap \
                                       results/solution/pcap_nodes/acc1.pcap \
                                       results/solution/pcap_nodes/acc2.pcap \
                                       results/solution/pcap_nodes/acc3.pcap \
                                       results/solution/pcap_nodes/acc4.pcap \
                                       results/solution/pcap_nodes/acc5.pcap \
                                       results/solution/pcap_nodes/acc6.pcap \
                                       results/solution/pcap_nodes/producer.pcap \
                                       results/solution/pcap_nodes/consumer.pcap
	python3 $^ $@

results/solution/disruption_times.pdf: experiment/tool/plot_latency.py results/solution/disruption_metrics.txt
	python3 $^ $@

results/solution/disruption_metrics.txt: experiment/tool/compute_latency_metrics.py results/solution/consumer_capture.csv results/solution/handoffs.txt
	python3 $^ $@

results/solution/loss_comparison.pdf: experiment/tool/plot_loss.py results/solution/loss_ratio.txt
	python3 $^ $@

results/solution/loss_ratio.txt: experiment/tool/compute_loss_metrics.py results/solution/consumer_capture.csv results/solution/handoffs.txt
	python3 $^ $@

results/solution/throughput_timeseries.pdf: experiment/tool/plot_throughput.py results/solution/consumer_capture.csv results/solution/handoffs.txt
	python3 $^ $@

results/solution/throughput_metrics.txt: experiment/tool/compute_throughput_metrics.py results/solution/consumer_capture.csv
	python3 $^ $@

results/solution/overhead_timeseries.pdf: experiment/tool/plot_overhead.py results/solution/network_overhead.csv results/solution/handoffs.txt results/main_overhead_limits.txt
	python3 $^ $@

results/solution/overhead_summary.pdf: experiment/tool/plot_overhead.py results/solution/network_overhead.csv results/solution/handoffs.txt results/main_overhead_limits.txt
	python3 $^ $@

results/solution/overhead_total.txt: experiment/tool/compute_overhead_metrics.py results/solution/network_overhead.csv results/solution/handoffs.txt | experiment/tool/plot_overhead.py
	python3 $^ $@
