                  $(PLOT_LOSS_SCRIPT) \
                  $(PLOT_OVERHEAD_SCRIPT) \
                  $(PLOT_OVERHEAD_YMAX_SCRIPT) \
                  $(PLOT_THROUGHPUT_SCRIPT) \
                  $(BASELINE_PROFILE_SUMMARY_SCRIPT) \
                  $(BASELINE_PROFILE_DISRUPTION_SCRIPT) \
                  $(BASELINE_PROFILE_COST_SCRIPT) \
                  $(PLOT_RESULT_METRICS_SCRIPT) \
                  $(PLOT_MAIN_RESULTS_SCRIPT)
PIPELINE_CONFIG_SRCS := $(BASELINE_PROFILE_CONFIG_MK)
TEST_TOOL_SRCS := experiment/tool/ndn.lua
PLOT_ENV_SRCS := experiment/tool/requirements.txt

# Host-side plotting environment (for re-generating figures without re-running experiments)
VENV_DIR := experiment/tool/.venv
