# Tooling split by pipeline:
# - EXPERIMENT_TOOL_SRCS: affects VM experiment run and CSV generation
# - PLOT_TOOL_SRCS: affects host-side figure regeneration only
# - TEST_TOOL_SRCS: affects validation/test flow only
# - PLOT_ENV_SRCS: affects host plotting Python environment
EXPERIMENT_RUN_SCRIPT := experiment/tool/exp.py
OVERHEAD_EXTRACT_SCRIPT := experiment/tool/extract_overhead_csv.py
EXPERIMENT_TOOL_SRCS := $(EXPERIMENT_RUN_SCRIPT) \
                        $(OVERHEAD_EXTRACT_SCRIPT)
PLOT_LATENCY_SCRIPT := experiment/tool/plot_latency.py
PLOT_LOSS_SCRIPT := experiment/tool/plot_loss.py
PLOT_OVERHEAD_SCRIPT := experiment/tool/plot_overhead.py
PLOT_OVERHEAD_YMAX_SCRIPT := experiment/tool/compute_overhead_ymax.py
PLOT_THROUGHPUT_SCRIPT := experiment/tool/plot_throughput.py
BASELINE_PROFILE_SUMMARY_SCRIPT := experiment/tool/summarize_nlsr_sensitivity.py
BASELINE_PROFILE_DISRUPTION_SCRIPT := experiment/tool/plot_nlsr_disruption_comparison.py
BASELINE_PROFILE_COST_SCRIPT := experiment/tool/plot_nlsr_network_cost_comparison.py
BASELINE_PROFILE_CONFIG_MK := experiment/tool/baseline_profiles.mk
PLOT_RESULT_METRICS_SCRIPT := experiment/tool/plot_result_metrics.py
