# Generate the paper
$(PAPER_PDF): $(MAIN_TEX) $(ALL_FIGURES) | $(PAPER_BIN)
	@echo "Compiling LaTeX with latexmk..."
	$(LATEXMK) $(LATEXMK_FLAGS) $(MAIN_TEX)
	cp $(PAPER_BIN)/$(notdir $(PAPER_PDF)) $(PAPER_PDF)

$(PAPER_BIN):
	mkdir -p $(PAPER_BIN)


